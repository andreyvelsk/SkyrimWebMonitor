{
  "name": "skyrimwebmonitor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A Vue 3 PWA companion app for The Elder Scrolls V: Skyrim. Monitors player stats, inventory, magic and hotkeys in real time over WebSocket. Designed primarily for the AYN Thor handheld.",
  "keywords": [
    "skyrim",
    "the-elder-scrolls",
    "pwa",
    "vue",
    "vue3",
    "vite",
    "websocket",
    "companion-app",
    "ayn-thor",
    "skse"
  ],
  "homepage": "https://andreyvelsk.github.io/SkyrimWebMonitor/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andreyvelsk/SkyrimWebMonitor.git"
  },
  "bugs": {
    "url": "https://github.com/andreyvelsk/SkyrimWebMonitor/issues"
  },
  "author": "Andrey Velsk (https://github.com/andreyvelsk)",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tsc": "tsc --noEmit",
    "export-fixtures": "node scripts/export-fixtures.js",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx --fix",
    "lint:css": "stylelint \"src/**/*.{vue,css,scss}\" --fix",
    "format": "prettier --write \"src/**/*.{vue,js,jsx,json,css,scss}\" && npm run lint:css"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vite-plugin-pwa": "^1.2.0",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "postcss-html": "^1.8.1",
    "postcss-preset-env": "^11.2.0",
    "prettier": "^3.8.1",
    "sass": "^1.99.0",
    "stylelint": "^17.6.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.2",
    "vue-eslint-parser": "^10.4.0",
    "ws": "^8.13.0"
  }
}