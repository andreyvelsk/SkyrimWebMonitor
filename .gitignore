# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
dist-electron
*.local

# Capacitor Android generated outputs. The native project is tracked, but web
# assets/config are regenerated by `npx cap sync android` in local builds and CI.
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json

# Map source PNG and generated DZI pyramid: kept out of git so the repo
# doesn't bloat each time the map is replaced. Re-generate via:
#   vips dzsave public/skyrim.png public/map-dzi/skyrim \
#     --layout dz --tile-size 512 --overlap 1 --suffix '.webp[Q=80]'
# The PNG itself should be stored in cloud storage / release assets and
# fetched as part of the build (or kept locally by developers).
public/map-dzi/
public/maps/

